{
  "name": "@skillbooks/cli",
  "version": "2.0.0",
  "description": "The Skillbooks CLI — create, validate, and publish skillbooks",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "skillbooks": "./dist/src/index.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsx src/index.ts",
    "test": "node --experimental-strip-types --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["skillbooks", "cli", "ai", "publish", "validate", "agent-skills"],
  "author": "Skillbooks <hello@skillbooks.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skillbooks-ai/creator-tools.git"
  },
  "homepage": "https://skillbooks.ai/developers",
  "dependencies": {
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
