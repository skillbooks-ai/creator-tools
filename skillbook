#!/usr/bin/env bash
# skillbook — Unified CLI for Skillbooks creator tools
# Usage: skillbook <command> [args...]
#
# Commands:
#   validate <path>    Validate a skillbook against FORMAT v1.0
#   init [path]        Initialize a new skillbook project (interactive)
#   index <path>       Build TAG-INDEX.json + regenerate SKILL.md TOC
#   account            Show credit balance and publisher status
#   signup             Open the Skillbooks signup page
#   publish <path>     Publish a skillbook to the platform
#   help               Show this help message

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VERSION="1.1.0"

usage() {
  cat <<EOF
skillbook v$VERSION — Skillbooks Creator Tools

Usage: skillbook <command> [args...]

Commands:
  validate <path>    Validate a skillbook against FORMAT v1.0
  init [path]        Initialize a new skillbook project (interactive)
  index <path>       Build TAG-INDEX.json and regenerate SKILL.md TOC
  account            Show credit balance and publisher status
  signup             Open the Skillbooks get-started page
  publish <path>     Publish a skillbook to the platform (coming soon)

Examples:
  skillbook init ./books
  skillbook validate ./my-book
  skillbook index ./my-book
  skillbook signup

Run 'skillbook <command> --help' for command-specific help.
EOF
}

case "${1:-help}" in
  validate)
    shift
    exec bash "$SCRIPT_DIR/validate/validate.sh" "$@"
    ;;
  init)
    shift
    exec bash "$SCRIPT_DIR/init/init.sh" "$@"
    ;;
  index)
    shift
    exec bash "$SCRIPT_DIR/index/index.sh" "$@"
    ;;
  account)
    shift
    exec bash "$SCRIPT_DIR/account/account.sh" "$@"
    ;;
  signup)
    echo ""
    echo "  Opening Skillbooks..."
    echo ""
    # Try platform-appropriate open command
    if command -v open &>/dev/null; then
      open "https://skillbooks.ai/start"
    elif command -v xdg-open &>/dev/null; then
      xdg-open "https://skillbooks.ai/start"
    else
      echo "  Open in your browser: https://skillbooks.ai/start"
    fi
    echo "  → https://skillbooks.ai/start"
    echo ""
    echo "  Choose your path:"
    echo "    • Start using Skillbooks (buy credits, consume content)"
    echo "    • Start publishing on Skillbooks (create, earn 80% revenue)"
    echo ""
    ;;
  publish)
    echo ""
    echo "  ⚠️  publish is not yet available."
    echo "  For now, push to a git repo under skillbooks-ai/ on GitHub."
    echo ""
    ;;
  help|--help|-h)
    usage
    ;;
  version|--version|-v)
    echo "skillbook v$VERSION"
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run 'skillbook help' for available commands."
    exit 1
    ;;
esac
